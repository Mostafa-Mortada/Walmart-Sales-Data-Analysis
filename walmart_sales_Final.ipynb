    "# 2) Median per Ship Mode (exclude Missing)\n",
    "median_map = df[df['Ship Mode'] != 'Missing'].groupby('Ship Mode')['Duration'].median()\n",
    "\n",
    "# 3) Assign with tie-breaking (prefer smaller median)\n",
    "def assign_mode(d):\n",
    "    diff = (median_map - d).abs()\n",
    "    return diff[diff == diff.min()].sort_values().index[0]\n",
    "\n",
    "# 4) Apply only on Missing\n",
    "mask = df['Ship Mode'] == 'Missing'\n",
    "df.loc[mask, 'Ship Mode'] = df.loc[mask, 'Duration'].apply(assign_mode)"
   ]
