    "    gap:12px;\n",
    "    margin-bottom:20px;\n",
    "}\n",
    "\n",
    ".members-label{\n",
    "    font-family:'Space Mono', monospace;\n",
    "    font-size:9px;\n",
    "    letter-spacing:0.25em;\n",
    "    text-transform:uppercase;\n",
    "    color:#4a5880;\n",
    "    white-space:nowrap;\n",
    "}\n",
    "\n",
    ".members-line{\n",
    "    flex:1;\n",
    "    height:1px;\n",
    "    background:#1a2444;\n",
    "}\n",
    "\n",
    "/* Members Grid */\n",
    ".members-grid{\n",
    "    display:grid;\n",
    "    grid-template-columns:repeat(3, 1fr);\n",
    "    gap:12px;\n",
    "}\n",
    "\n",
    ".member-card{\n",
    "    background:rgba(255,255,255,0.025);\n",
    "    border:1px solid #172040;\n",
    "    border-radius:4px;\n",
    "    padding:12px 16px;\n",
    "    display:flex;\n",
    "    align-items:center;\n",
    "    gap:12px;\n",
    "    transition:\n",
    "        border-color 0.25s ease,\n",
    "        transform 0.25s ease,\n",
    "        background 0.25s ease;\n",
    "}\n",
    "\n",
    ".member-card:hover{\n",
    "    border-color:rgba(255,194,32,0.45);\n",
    "    transform:translateY(-3px);\n",
    "    background:rgba(255,194,32,0.04);\n",
    "}\n",
    "\n",
    ".member-number{\n",
    "    font-family:'Space Mono', monospace;\n",
    "    font-size:10px;\n",
    "    color:#ffc220;\n",
    "    opacity:0.7;\n",
    "    width:22px;\n",
    "}\n",
    "\n",
    ".member-name{\n",
    "    font-size:13px;\n",
    "    font-weight:400;\n",
    "    color:#d0dcfa;\n",
    "    letter-spacing:0.02em;\n",
    "}\n",
    "\n",
    "/* Bottom Bar */\n",
    ".bottom-bar{\n",
    "    display:flex;\n",
    "    align-items:center;\n",
    "    justify-content:space-between;\n",
    "    margin-top:44px;\n",
    "    padding-top:20px;\n",
    "    border-top:1px solid #131d3a;\n",
    "}\n",
    "\n",
    ".course-pill{\n",
    "    display:flex;\n",
    "    align-items:center;\n",
    "    gap:10px;\n",
    "}\n",
    "\n",
    ".course-pill .pill-dot{\n",
    "    width:8px;\n",
    "    height:8px;\n",
    "    background:#ffc220;\n",
    "    border-radius:50%;\n",
    "}\n",
    "\n",
    ".course-pill span{\n",
    "    font-family:'Space Mono', monospace;\n",
    "    font-size:11px;\n",
    "    letter-spacing:0.1em;\n",
    "    color:#ffc220;\n",
    "}\n",
    "\n",
    ".analytics-label{\n",
    "    font-family:'Space Mono', monospace;\n",
    "    font-size:9px;\n",
    "    letter-spacing:0.2em;\n",
    "    color:#2a3a62;\n",
    "    text-transform:uppercase;\n",
    "}\n",
    "\n",
    "/* Responsive */\n",
    "@media (max-width:768px){\n",
    "\n",
    "    .content{\n",
    "        padding:40px 28px;\n",
    "    }\n",
    "\n",
    "    .main-title{\n",
    "        font-size:64px;\n",
    "    }\n",
    "\n",
    "    .members-grid{\n",
    "        grid-template-columns:1fr;\n",
    "    }\n",
    "\n",
    "    .header{\n",
    "        flex-direction:column;\n",
    "        gap:24px;\n",
    "    }\n",
    "}\n",
    "\n",
    "</style>\n",
    "</head>\n",
