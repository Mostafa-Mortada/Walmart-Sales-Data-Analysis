    "    color:#ffc220;\n",
    "}\n",
    "\n",
    ".uni-name{\n",
    "    font-size:15px;\n",
    "    font-weight:500;\n",
    "    color:#dbe6ff;\n",
    "    line-height:1.6;\n",
    "}\n",
    "\n",
    ".faculty-name{\n",
    "    font-size:12px;\n",
    "    font-weight:300;\n",
    "    color:#7b8eb7;\n",
    "    margin-top:2px;\n",
    "    letter-spacing:0.03em;\n",
    "}\n",
    "\n",
    "/* Team Badge */\n",
    ".team-badge{\n",
    "    background:#ffc220;\n",
    "    color:#0a0f1e;\n",
    "    border-radius:4px;\n",
    "    padding:12px 18px;\n",
    "    text-align:center;\n",
    "    flex-shrink:0;\n",
    "    box-shadow:0 0 20px rgba(255,194,32,0.25);\n",
    "}\n",
    "\n",
    ".team-badge .label{\n",
    "    font-family:'Space Mono', monospace;\n",
    "    font-size:9px;\n",
    "    letter-spacing:0.2em;\n",
    "    text-transform:uppercase;\n",
    "    font-weight:700;\n",
    "    display:block;\n",
    "    margin-bottom:4px;\n",
    "}\n",
    "\n",
    ".team-badge .number{\n",
    "    font-family:'Bebas Neue', sans-serif;\n",
    "    font-size:54px;\n",
    "    line-height:1;\n",
    "}\n",
    "\n",
    "/* Divider */\n",
    ".divider{\n",
    "    display:flex;\n",
    "    align-items:center;\n",
    "    gap:16px;\n",
    "    margin-bottom:40px;\n",
    "}\n",
    "\n",
    ".divider-line{\n",
    "    flex:1;\n",
    "    height:1px;\n",
    "    background:linear-gradient(\n",
    "        90deg,\n",
    "        transparent,\n",
    "        #1e2d5a 30%,\n",
    "        #1e2d5a 70%,\n",
    "        transparent\n",
    "    );\n",
    "}\n",
    "\n",
    ".divider-icon{\n",
    "    font-size:11px;\n",
    "    letter-spacing:0.2em;\n",
    "    color:#ffc220;\n",
    "    font-family:'Space Mono', monospace;\n",
    "    text-transform:uppercase;\n",
    "    white-space:nowrap;\n",
    "}\n",
    "\n",
    "/* Title Area */\n",
    ".title-area{\n",
    "    position:relative;\n",
    "    margin-bottom:48px;\n",
    "}\n",
    "\n",
    "/* Analytics Background */\n",
    ".chart-bg{\n",
    "    position:absolute;\n",
    "    right:0;\n",
    "    top:-20px;\n",
    "    width:300px;\n",
    "    height:180px;\n",
    "    opacity:0.08;\n",
    "    background:\n",
    "        linear-gradient(120deg, transparent 20%, #ffc220 20%, #ffc220 22%, transparent 22%),\n",
    "        linear-gradient(140deg, transparent 35%, #ffc220 35%, #ffc220 37%, transparent 37%),\n",
    "        linear-gradient(160deg, transparent 50%, #ffc220 50%, #ffc220 52%, transparent 52%);\n",
    "    pointer-events:none;\n",
    "}\n",
    "\n",
    "/* Course Tag */\n",
    ".course-tag{\n",
    "    display:inline-block;\n",
    "    font-family:'Space Mono', monospace;\n",
    "    font-size:10px;\n",
    "    letter-spacing:0.25em;\n",
    "    text-transform:uppercase;\n",
    "    color:#6b7fa8;\n",
    "    margin-bottom:18px;\n",
    "}\n",
    "\n",
    "/* Spark Icon */\n",
    ".spark{\n",
    "    color:#ffc220;\n",
    "    font-size:36px;\n",
    "    margin-bottom:10px;\n",
    "    text-shadow:0 0 15px rgba(255,194,32,0.35);\n",
    "}\n",
    "\n",
    "/* Main Title */\n",
    ".main-title{\n",
    "    font-family:'Bebas Neue', sans-serif;\n",
    "    font-size:96px;\n",
    "    line-height:0.9;\n",
