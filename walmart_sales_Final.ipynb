    "def fill_ship_mode(df):\n",
    "    # Build a lookup: Order ID -> Ship Mode (from non-missing rows)\n",
    "    order_ship_map = (\n",
    "        df[df['Ship Mode'].notna()]\n",
    "        .drop_duplicates(subset='Order ID')\n",
    "        .set_index('Order ID')['Ship Mode']\n",
    "    )\n",
    "\n",
    "    def resolve(row):\n",
    "        if pd.notna(row['Ship Mode']):\n",
    "            return row['Ship Mode']  # Already filled\n",
    "        ship = order_ship_map.get(row['Order ID'])\n",
    "        return ship if ship is not None else 'Missing'\n",
    "\n",
    "    df['Ship Mode'] = df.apply(resolve, axis=1)\n",
    "    return df\n",
    "\n",
    "df = fill_ship_mode(df)"
   ]
