    "    text-shadow:\n",
    "        0 0 10px rgba(255,255,255,0.05),\n",
    "        0 0 30px rgba(255,194,32,0.08);\n",
    "}\n",
    "\n",
    ".main-title .highlight{\n",
    "    color:#ffc220;\n",
    "    display:block;\n",
    "}\n",
    "\n",
    "/* Subtitle Row */\n",
    ".subtitle-row{\n",
    "    display:flex;\n",
    "    align-items:center;\n",
    "    gap:20px;\n",
    "    margin-top:24px;\n",
    "    flex-wrap:wrap;\n",
    "}\n",
    "\n",
    ".subtitle-tag{\n",
    "    display:inline-flex;\n",
    "    align-items:center;\n",
    "    gap:8px;\n",
    "    background:rgba(255,255,255,0.04);\n",
