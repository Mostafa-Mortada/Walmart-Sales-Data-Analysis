 "cells": [
  {
   "cell_type": "code",
   "execution_count": 330,
   "id": "a2b142a9",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/html": [
       "\n",
       "<!DOCTYPE html>\n",
       "<html lang=\"en\">a\n",
       "<head>\n",
       "<meta charset=\"UTF-8\"/>\n",
       "<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"/>\n",
       "<title>Walmart Sales Analysis - Cover</title>\n",
       "\n",
       "<link href=\"https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&family=Space+Mono:wght@400;700&display=swap\" rel=\"stylesheet\"/>\n",
       "\n",
       "<style>\n",
       "\n",
       "*{\n",
       "    margin:0;\n",
       "    padding:0;\n",
       "    box-sizing:border-box;\n",
       "}\n",
       "\n",
       "body{\n",
       "    background:#0a0f1e;\n",
       "    min-height:100vh;\n",
       "    display:flex;\n",
       "    align-items:center;\n",
       "    justify-content:center;\n",
       "    padding:40px 20px;\n",
       "    font-family:'DM Sans',sans-serif;\n",
       "    overflow-x:hidden;\n",
       "}\n",
       "\n",
       "/* Main Page */\n",
       ".page{\n",
       "    width:950px;\n",
       "    max-width:100%;\n",
       "    background:#0d1428;\n",
       "    border:1px solid #1e2d5a;\n",
       "    border-radius:8px;\n",
       "    overflow:hidden;\n",
       "    position:relative;\n",
       "    box-shadow:\n",
       "        0 0 30px rgba(0,0,0,0.4),\n",
       "        0 0 80px rgba(255,194,32,0.04);\n",
       "}\n",
       "\n",
       "/* Top Stripe */\n",
       ".top-stripe{\n",
       "    height:6px;\n",
       "    background:linear-gradient(\n",
       "        90deg,\n",
       "        #ffc220 0%,\n",
       "        #ffd966 50%,\n",
       "        #ffc220 100%\n",
       "    );\n",
       "    box-shadow:0 0 20px rgba(255,194,32,0.2);\n",
       "}\n",
       "\n",
       "/* Bottom Stripe */\n",
       ".bottom-stripe{\n",
       "    height:4px;\n",
       "    background:linear-gradient(\n",
       "        90deg,\n",
       "        #0d1428 0%,\n",
       "        #ffc220 30%,\n",
       "        #ffd966 50%,\n",
       "        #ffc220 70%,\n",
       "        #0d1428 100%\n",
       "    );\n",
       "    opacity:0.7;\n",
       "    box-shadow:0 0 20px rgba(255,194,32,0.15);\n",
       "}\n",
       "\n",
       "/* Grid Background */\n",
       ".grid-bg{\n",
       "    position:absolute;\n",
       "    inset:0;\n",
       "    background-image:\n",
       "        linear-gradient(rgba(255,194,32,0.03) 1px, transparent 1px),\n",
       "        linear-gradient(90deg, rgba(255,194,32,0.03) 1px, transparent 1px);\n",
       "    background-size:40px 40px;\n",
       "    pointer-events:none;\n",
       "}\n",
       "\n",
       "/* Corners */\n",
       ".corner{\n",
       "    position:absolute;\n",
       "    width:80px;\n",
       "    height:80px;\n",
       "    border-color:#ffc220;\n",
       "    border-style:solid;\n",
       "    opacity:0.25;\n",
       "}\n",
       "\n",
       ".corner-tl{\n",
       "    top:20px;\n",
       "    left:20px;\n",
       "    border-width:2px 0 0 2px;\n",
       "}\n",
       "\n",
       ".corner-tr{\n",
       "    top:20px;\n",
       "    right:20px;\n",
       "    border-width:2px 2px 0 0;\n",
       "}\n",
       "\n",
       ".corner-bl{\n",
       "    bottom:20px;\n",
       "    left:20px;\n",
       "    border-width:0 0 2px 2px;\n",
       "}\n",
       "\n",
       ".corner-br{\n",
       "    bottom:20px;\n",
       "    right:20px;\n",
       "    border-width:0 2px 2px 0;\n",
       "}\n",
       "\n",
       ".content{\n",
       "    position:relative;\n",
       "    z-index:1;\n",
       "    padding:60px 70px 50px;\n",
       "}\n",
       "\n",
       "/* Header */\n",
       ".header{\n",
       "    display:flex;\n",
       "    align-items:flex-start;\n",
       "    justify-content:space-between;\n",
       "    margin-bottom:50px;\n",
       "}\n",
       "\n",
       ".uni-info{\n",
       "    flex:1;\n",
       "}\n",
       "\n",
       ".uni-badge{\n",
       "    display:inline-flex;\n",
       "    align-items:center;\n",
       "    gap:10px;\n",
       "    background:rgba(255,194,32,0.08);\n",
       "    border:1px solid rgba(255,194,32,0.25);\n",
       "    border-radius:3px;\n",
       "    padding:8px 16px;\n",
       "    margin-bottom:14px;\n",
       "}\n",
       "\n",
       ".uni-badge .dot{\n",
       "    width:7px;\n",
       "    height:7px;\n",
       "    background:#ffc220;\n",
       "    border-radius:50%;\n",
       "}\n",
       "\n",
       ".uni-badge span{\n",
       "    font-family:'Space Mono', monospace;\n",
       "    font-size:10px;\n",
       "    letter-spacing:0.15em;\n",
       "    text-transform:uppercase;\n",
       "    color:#ffc220;\n",
       "}\n",
       "\n",
       ".uni-name{\n",
       "    font-size:15px;\n",
       "    font-weight:500;\n",
       "    color:#dbe6ff;\n",
       "    line-height:1.6;\n",
       "}\n",
       "\n",
       ".faculty-name{\n",
       "    font-size:12px;\n",
       "    font-weight:300;\n",
       "    color:#7b8eb7;\n",
       "    margin-top:2px;\n",
       "    letter-spacing:0.03em;\n",
       "}\n",
       "\n",
       "/* Team Badge */\n",
       ".team-badge{\n",
       "    background:#ffc220;\n",
       "    color:#0a0f1e;\n",
       "    border-radius:4px;\n",
       "    padding:12px 18px;\n",
       "    text-align:center;\n",
       "    flex-shrink:0;\n",
       "    box-shadow:0 0 20px rgba(255,194,32,0.25);\n",
       "}\n",
       "\n",
       ".team-badge .label{\n",
       "    font-family:'Space Mono', monospace;\n",
       "    font-size:9px;\n",
       "    letter-spacing:0.2em;\n",
       "    text-transform:uppercase;\n",
       "    font-weight:700;\n",
       "    display:block;\n",
       "    margin-bottom:4px;\n",
       "}\n",
       "\n",
       ".team-badge .number{\n",
       "    font-family:'Bebas Neue', sans-serif;\n",
       "    font-size:54px;\n",
       "    line-height:1;\n",
       "}\n",
       "\n",
       "/* Divider */\n",
       ".divider{\n",
       "    display:flex;\n",
       "    align-items:center;\n",
       "    gap:16px;\n",
       "    margin-bottom:40px;\n",
       "}\n",
       "\n",
       ".divider-line{\n",
       "    flex:1;\n",
       "    height:1px;\n",
       "    background:linear-gradient(\n",
       "        90deg,\n",
       "        transparent,\n",
       "        #1e2d5a 30%,\n",
       "        #1e2d5a 70%,\n",
       "        transparent\n",
       "    );\n",
       "}\n",
       "\n",
       ".divider-icon{\n",
       "    font-size:11px;\n",
       "    letter-spacing:0.2em;\n",
       "    color:#ffc220;\n",
       "    font-family:'Space Mono', monospace;\n",
       "    text-transform:uppercase;\n",
       "    white-space:nowrap;\n",
       "}\n",
       "\n",
       "/* Title Area */\n",
       ".title-area{\n",
       "    position:relative;\n",
       "    margin-bottom:48px;\n",
       "}\n",
       "\n",
       "/* Analytics Background */\n",
       ".chart-bg{\n",
       "    position:absolute;\n",
       "    right:0;\n",
       "    top:-20px;\n",
       "    width:300px;\n",
       "    height:180px;\n",
       "    opacity:0.08;\n",
       "    background:\n",
       "        linear-gradient(120deg, transparent 20%, #ffc220 20%, #ffc220 22%, transparent 22%),\n",
       "        linear-gradient(140deg, transparent 35%, #ffc220 35%, #ffc220 37%, transparent 37%),\n",
       "        linear-gradient(160deg, transparent 50%, #ffc220 50%, #ffc220 52%, transparent 52%);\n",
       "    pointer-events:none;\n",
       "}\n",
       "\n",
       "/* Course Tag */\n",
       ".course-tag{\n",
       "    display:inline-block;\n",
       "    font-family:'Space Mono', monospace;\n",
       "    font-size:10px;\n",
       "    letter-spacing:0.25em;\n",
       "    text-transform:uppercase;\n",
       "    color:#6b7fa8;\n",
       "    margin-bottom:18px;\n",
       "}\n",
       "\n",
       "/* Spark Icon */\n",
       ".spark{\n",
       "    color:#ffc220;\n",
       "    font-size:36px;\n",
       "    margin-bottom:10px;\n",
       "    text-shadow:0 0 15px rgba(255,194,32,0.35);\n",
       "}\n",
       "\n",
       "/* Main Title */\n",
       ".main-title{\n",
       "    font-family:'Bebas Neue', sans-serif;\n",
       "    font-size:96px;\n",
       "    line-height:0.9;\n",
       "    letter-spacing:0.06em;\n",
       "    color:#ffffff;\n",
       "    margin-bottom:14px;\n",
       "    text-shadow:\n",
       "        0 0 10px rgba(255,255,255,0.05),\n",
       "        0 0 30px rgba(255,194,32,0.08);\n",
       "}\n",
       "\n",
       ".main-title .highlight{\n",
       "    color:#ffc220;\n",
       "    display:block;\n",
       "}\n",
       "\n",
       "/* Subtitle Row */\n",
       ".subtitle-row{\n",
       "    display:flex;\n",
       "    align-items:center;\n",
       "    gap:20px;\n",
       "    margin-top:24px;\n",
       "    flex-wrap:wrap;\n",
       "}\n",
       "\n",
       ".subtitle-tag{\n",
       "    display:inline-flex;\n",
       "    align-items:center;\n",
       "    gap:8px;\n",
       "    background:rgba(255,255,255,0.04);\n",
       "    border:1px solid #1e2d5a;\n",
       "    border-radius:3px;\n",
       "    padding:7px 14px;\n",
       "}\n",
       "\n",
       ".subtitle-tag .icon{\n",
       "    width:6px;\n",
       "    height:6px;\n",
       "    background:#ffc220;\n",
       "    transform:rotate(45deg);\n",
       "}\n",
       "\n",
       ".subtitle-tag span{\n",
       "    font-size:12px;\n",
       "    color:#9eb0d8;\n",
       "    letter-spacing:0.05em;\n",
       "}\n",
       "\n",
       "/* Data Bars */\n",
       ".data-bars{\n",
       "    display:flex;\n",
       "    align-items:flex-end;\n",
       "    gap:5px;\n",
       "    height:50px;\n",
       "    opacity:0.35;\n",
       "    margin-top:30px;\n",
       "    margin-bottom:40px;\n",
       "}\n",
       "\n",
       ".bar{\n",
       "    flex:1;\n",
       "    background:#ffc220;\n",
       "    border-radius:2px 2px 0 0;\n",
       "    min-width:8px;\n",
       "    max-width:14px;\n",
       "}\n",
       "\n",
       "/* Members Section */\n",
       ".members-section{\n",
       "    margin-top:10px;\n",
       "}\n",
       "\n",
       ".members-header{\n",
       "    display:flex;\n",
       "    align-items:center;\n",
       "    gap:12px;\n",
       "    margin-bottom:20px;\n",
       "}\n",
       "\n",
       ".members-label{\n",
       "    font-family:'Space Mono', monospace;\n",
       "    font-size:9px;\n",
       "    letter-spacing:0.25em;\n",
       "    text-transform:uppercase;\n",
       "    color:#4a5880;\n",
       "    white-space:nowrap;\n",
       "}\n",
       "\n",
       ".members-line{\n",
       "    flex:1;\n",
       "    height:1px;\n",
       "    background:#1a2444;\n",
       "}\n",
       "\n",
       "/* Members Grid */\n",
       ".members-grid{\n",
       "    display:grid;\n",
       "    grid-template-columns:repeat(3, 1fr);\n",
       "    gap:12px;\n",
       "}\n",
       "\n",
       ".member-card{\n",
       "    background:rgba(255,255,255,0.025);\n",
       "    border:1px solid #172040;\n",
       "    border-radius:4px;\n",
       "    padding:12px 16px;\n",
       "    display:flex;\n",
       "    align-items:center;\n",
       "    gap:12px;\n",
       "    transition:\n",
       "        border-color 0.25s ease,\n",
       "        transform 0.25s ease,\n",
       "        background 0.25s ease;\n",
       "}\n",
       "\n",
       ".member-card:hover{\n",
       "    border-color:rgba(255,194,32,0.45);\n",
       "    transform:translateY(-3px);\n",
       "    background:rgba(255,194,32,0.04);\n",
       "}\n",
       "\n",
       ".member-number{\n",
       "    font-family:'Space Mono', monospace;\n",
       "    font-size:10px;\n",
       "    color:#ffc220;\n",
       "    opacity:0.7;\n",
       "    width:22px;\n",
       "}\n",
       "\n",
       ".member-name{\n",
       "    font-size:13px;\n",
       "    font-weight:400;\n",
       "    color:#d0dcfa;\n",
       "    letter-spacing:0.02em;\n",
       "}\n",
       "\n",
       "/* Bottom Bar */\n",
       ".bottom-bar{\n",
       "    display:flex;\n",
       "    align-items:center;\n",
       "    justify-content:space-between;\n",
       "    margin-top:44px;\n",
       "    padding-top:20px;\n",
       "    border-top:1px solid #131d3a;\n",
       "}\n",
       "\n",
       ".course-pill{\n",
       "    display:flex;\n",
       "    align-items:center;\n",
       "    gap:10px;\n",
       "}\n",
       "\n",
       ".course-pill .pill-dot{\n",
       "    width:8px;\n",
       "    height:8px;\n",
       "    background:#ffc220;\n",
       "    border-radius:50%;\n",
       "}\n",
       "\n",
       ".course-pill span{\n",
       "    font-family:'Space Mono', monospace;\n",
       "    font-size:11px;\n",
       "    letter-spacing:0.1em;\n",
       "    color:#ffc220;\n",
       "}\n",
       "\n",
       ".analytics-label{\n",
       "    font-family:'Space Mono', monospace;\n",
       "    font-size:9px;\n",
       "    letter-spacing:0.2em;\n",
       "    color:#2a3a62;\n",
       "    text-transform:uppercase;\n",
       "}\n",
       "\n",
       "/* Responsive */\n",
       "@media (max-width:768px){\n",
       "\n",
       "    .content{\n",
       "        padding:40px 28px;\n",
       "    }\n",
       "\n",
       "    .main-title{\n",
       "        font-size:64px;\n",
       "    }\n",
       "\n",
       "    .members-grid{\n",
       "        grid-template-columns:1fr;\n",
       "    }\n",
       "\n",
       "    .header{\n",
       "        flex-direction:column;\n",
       "        gap:24px;\n",
       "    }\n",
       "}\n",
       "\n",
       "</style>\n",
       "</head>\n",
       "\n",
       "<body>\n",
       "\n",
       "<div class=\"page\">\n",
       "\n",
       "    <div class=\"top-stripe\"></div>\n",
       "\n",
       "    <div class=\"grid-bg\"></div>\n",
       "\n",
       "    <div class=\"corner corner-tl\"></div>\n",
       "    <div class=\"corner corner-tr\"></div>\n",
       "    <div class=\"corner corner-bl\"></div>\n",
       "    <div class=\"corner corner-br\"></div>\n",
       "\n",
       "    <div class=\"content\">\n",
       "\n",
       "        <!-- Header -->\n",
       "        <div class=\"header\">\n",
       "\n",
       "            <div class=\"uni-info\">\n",
       "\n",
       "                <div class=\"uni-badge\">\n",
       "                    <div class=\"dot\"></div>\n",
       "                    <span>Academic Project</span>\n",
       "                </div>\n",
       "\n",
       "                <div class=\"uni-name\">\n",
       "                    Ain Shams University\n",
       "                </div>\n",
       "\n",
       "                <div class=\"faculty-name\">\n",
       "                    Faculty of Computer and Information Systems\n",
       "                </div>\n",
       "\n",
       "            </div>\n",
       "\n",
       "            <div class=\"team-badge\">\n",
       "                <span class=\"label\">Team ID</span>\n",
       "                <span class=\"number\">23</span>\n",
       "            </div>\n",
       "\n",
       "        </div>\n",
       "\n",
       "        <!-- Divider -->\n",
       "        <div class=\"divider\">\n",
       "            <div class=\"divider-line\"></div>\n",
       "            <div class=\"divider-icon\">\n",
       "                * Data Analysis Project *\n",
       "            </div>\n",
       "            <div class=\"divider-line\"></div>\n",
       "        </div>\n",
       "\n",
       "        <!-- Title -->\n",
       "        <div class=\"title-area\">\n",
       "\n",
       "            <div class=\"chart-bg\"></div>\n",
       "\n",
       "            <div class=\"course-tag\">\n",
       "                Business Intelligence Course\n",
       "            </div>\n",
       "\n",
       "            <div class=\"spark\">✦</div>\n",
       "\n",
       "            <div class=\"main-title\">\n",
       "                Walmart\n",
       "                <span class=\"highlight\">Sales</span>\n",
       "                Analysis\n",
       "            </div>\n",
       "\n",
       "            <div class=\"subtitle-row\">\n",
       "\n",
       "                <div class=\"subtitle-tag\">\n",
       "                    <div class=\"icon\"></div>\n",
       "                    <span>Retail & Consumer Insights</span>\n",
       "                </div>\n",
       "\n",
       "                <div class=\"subtitle-tag\">\n",
       "                    <div class=\"icon\"></div>\n",
       "                    <span>Predictive Analytics</span>\n",
       "                </div>\n",
       "\n",
       "                <div class=\"subtitle-tag\">\n",
       "                    <div class=\"icon\"></div>\n",
       "                    <span>Dashboard Reporting</span>\n",
       "                </div>\n",
       "\n",
       "            </div>\n",
       "\n",
       "        </div>\n",
       "\n",
       "        <!-- Data Bars -->\n",
       "        <div class=\"data-bars\">\n",
       "\n",
       "            <div class=\"bar\" style=\"height:25%\"></div>\n",
       "            <div class=\"bar\" style=\"height:55%\"></div>\n",
       "            <div class=\"bar\" style=\"height:38%\"></div>\n",
       "            <div class=\"bar\" style=\"height:80%\"></div>\n",
       "            <div class=\"bar\" style=\"height:60%\"></div>\n",
       "            <div class=\"bar\" style=\"height:90%\"></div>\n",
       "            <div class=\"bar\" style=\"height:72%\"></div>\n",
       "            <div class=\"bar\" style=\"height:45%\"></div>\n",
       "            <div class=\"bar\" style=\"height:100%\"></div>\n",
       "            <div class=\"bar\" style=\"height:65%\"></div>\n",
       "            <div class=\"bar\" style=\"height:48%\"></div>\n",
       "            <div class=\"bar\" style=\"height:78%\"></div>\n",
       "            <div class=\"bar\" style=\"height:55%\"></div>\n",
       "            <div class=\"bar\" style=\"height:33%\"></div>\n",
       "            <div class=\"bar\" style=\"height:70%\"></div>\n",
       "            <div class=\"bar\" style=\"height:88%\"></div>\n",
       "            <div class=\"bar\" style=\"height:42%\"></div>\n",
       "            <div class=\"bar\" style=\"height:62%\"></div>\n",
       "            <div class=\"bar\" style=\"height:50%\"></div>\n",
       "            <div class=\"bar\" style=\"height:95%\"></div>\n",
       "\n",
       "        </div>\n",
       "\n",
       "        <!-- Members -->\n",
       "        <div class=\"members-section\">\n",
       "\n",
       "            <div class=\"members-header\">\n",
       "                <div class=\"members-label\">\n",
       "                    Team Members\n",
       "                </div>\n",
       "                <div class=\"members-line\"></div>\n",
       "            </div>\n",
       "\n",
       "            <div class=\"members-grid\">\n",
       "\n",
       "                <div class=\"member-card\">\n",
       "                    <span class=\"member-number\">01</span>\n",
       "                    <span class=\"member-name\">Moustafa Mortada Mohamed</span>\n",
       "                </div>\n",
       "\n",
       "                <div class=\"member-card\">\n",
       "                    <span class=\"member-number\">02</span>\n",
       "                    <span class=\"member-name\">Ammar Mohamed Ali</span>\n",
       "                </div>\n",
       "\n",
       "                <div class=\"member-card\">\n",
       "                    <span class=\"member-number\">03</span>\n",
       "                    <span class=\"member-name\">Omar Karm Sayed</span>\n",
       "                </div>\n",
       "\n",
       "                <div class=\"member-card\">\n",
       "                    <span class=\"member-number\">04</span>\n",
       "                    <span class=\"member-name\">Sara Mohsen Mohamed</span>\n",
       "                </div>\n",
       "\n",
       "                <div class=\"member-card\">\n",
       "                    <span class=\"member-number\">05</span>\n",
       "                    <span class=\"member-name\">Nada Mohamed Mahmoud</span>\n",
       "                </div>\n",
       "\n",
       "                <div class=\"member-card\">\n",
       "                    <span class=\"member-number\">06</span>\n",
       "                    <span class=\"member-name\">Hadeel Mohamed Thabet</span>\n",
       "                </div>\n",
       "\n",
       "            </div>\n",
       "\n",
       "        </div>\n",
       "\n",
       "        <!-- Bottom -->\n",
       "        <div class=\"bottom-bar\">\n",
       "\n",
       "            <div class=\"course-pill\">\n",
       "                <div class=\"pill-dot\"></div>\n",
       "                <span>Business Intelligence</span>\n",
       "            </div>\n",
       "\n",
       "            <div class=\"analytics-label\">\n",
       "                Walmart • Retail Analytics • 2025\n",
       "            </div>\n",
       "\n",
       "        </div>\n",
       "\n",
       "    </div>\n",
       "\n",
       "    <div class=\"bottom-stripe\"></div>\n",
       "\n",
       "</div>\n",
       "\n",
       "</body>\n",
