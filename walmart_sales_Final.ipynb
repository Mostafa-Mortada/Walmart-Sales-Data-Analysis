    "# Step 2: Stationarize the series\n",
    "def stationarize_series(series):\n",
    "    # Calculate rolling statistics\n",
    "    rolling_mean = series.rolling(window=12).mean()\n",
    "    rolling_std = series.rolling(window=12).std()\n",
    "    \n",
    "    # Plot rolling statistics\n",
    "    plt.figure(figsize=(12, 6))\n",
    "    plt.plot(series, label='Original', color='blue')\n",
    "    plt.plot(rolling_mean, label='Rolling Mean (12 Months)', color='red')\n",
    "    plt.plot(rolling_std, label='Rolling Std (12 Months)', color='green')\n",
    "    plt.title('Rolling Mean & Standard Deviation')\n",
    "    plt.xlabel('Date')\n",
    "    plt.ylabel('Sales')\n",
    "    plt.legend(loc='best')\n",
    "    plt.grid(True)\n",
    "    plt.show()\n",
    "    \n",
    "    # Perform Dickey-Fuller test\n",
    "    print('--- Results of Dickey-Fuller Test ---')\n",
    "    result = adfuller(series)\n",
    "    print('ADF Statistic:', result[0])\n",
    "    print('p-value:', result[1])\n",
    "    print('Critical Values:')\n",
    "    for key, value in result[4].items():\n",
    "        print('\\t{}: {}'.format(key, value))\n",
    "\n",
    "# Run test on original series\n",
    "stationarize_series(monthly_sales)"
   ]
