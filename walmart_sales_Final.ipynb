    "def check_outliers(df, col):\n",
    "    # 1. Get Q1 and Q3 using describe\n",
    "    q1, q3 = df[col].describe()[[\"25%\", \"75%\"]]\n",
    "    iqr = q3 - q1\n",
    "\n",
    "    # 2. Calculate bounds\n",
    "    lower = q1 - 1.5 * iqr\n",
    "    upper = q3 + 1.5 * iqr\n",
    "\n",
    "    # 3. Count outliers\n",
    "    is_outlier = (df[col] < lower) | (df[col] > upper)\n",
    "    count = is_outlier.sum()\n",
    "    pct = is_outlier.mean() * 100\n",
    "\n",
    "    # 4. Print clean results\n",
    "    print(\n",
    "        f\"{col.title():<12} | {lower:<12.2f} | {upper:<12.2f} | {count} ({pct:.1f}%)\"\n",
    "    )\n",
    "    return lower, upper\n",
    "\n",
    "\n",
    "# --- Run and Print Results ---\n",
    "bounds = {}\n",
    "\n",
    "print(\"-\" * 65)\n",
    "print(f\"{'Column':<12} | {'Lower Bound':<12} | {'Upper Bound':<12} | Outliers (%)\")\n",
    "print(\"-\" * 65)\n",
    "\n",
    "for col in cols:\n",
    "    bounds[col] = check_outliers(df, col)\n",
    "\n",
    "print(\"-\" * 65)"
   ]
