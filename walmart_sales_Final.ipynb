    "# Proper-Casing\n",
    "df_model['State'] = df_model['State'].str.title()\n",
    "\n",
    "# Group rare states in `Other` state\n",
    "state_counts = df_model['State'].value_counts()\n",
    "rare_states = state_counts[state_counts < 50].index\n",
    "df_model['State'] = df_model['State'].where(\n",
    "    ~df_model['State'].isin(rare_states), other='Other'\n",
    ")\n",
    "print(f'Rare states grouped: {len(rare_states)} -> Other')\n",
    "print(f'State values remaining: {df_model[\"State\"].nunique()}')\n",
    "\n",
    "ohe_cols = ['Ship Mode', 'Segment', 'Sub-Category', 'State']\n",
    "df_model = pd.get_dummies(df_model, columns=ohe_cols, drop_first=True, dtype=int)\n",
